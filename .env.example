# ─── Supabase ───────────────────────────────────────────────
# Public anon key (safe for client-side, protected by RLS)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key (server-only, bypasses RLS — NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Resend (Email) ─────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
# Verified sender domain/email
RESEND_FROM_EMAIL=Imperial <noreply@yourdomain.com>

# ─── Restaurant ─────────────────────────────────────────────
# Where order/event notifications are sent
RESTAURANT_EMAIL=info@restaurant-imperial.be

# ─── Admin ──────────────────────────────────────────────────
# Shared password for admin dashboard login
IMPERIAL_ADMIN_PASSWORD=your-secure-password
